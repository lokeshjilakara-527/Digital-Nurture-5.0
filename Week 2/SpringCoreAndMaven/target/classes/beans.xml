<?xml version="1.0" encoding="UTF-8"?>
<!-- this file tells spring which objects (beans) to create and how to connect them -->
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- engine bean -->
    <bean id="petrolEngine" class="springcore.PetrolEngine"/>
    <bean id="dieselEngine" class="springcore.DieselEngine"/>

    <!-- car bean, engine is passed using constructor, color is passed using setter -->
    <bean id="myCar" class="springcore.Car">
        <constructor-arg ref="petrolEngine"/>
        <property name="carColor" value="Red"/>
    </bean>

</beans>
